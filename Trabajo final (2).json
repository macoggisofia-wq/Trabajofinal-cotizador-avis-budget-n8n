    {
      "parameters": {
        "jsCode": "for (const item of $input.all()) {\n  \n  // Función inteligente para buscar un campo sin importar mayúsculas, minúsculas,\n  // o si n8n lo traduce visualmente (ej. busca \"Mail\" y si no lo encuentra, busca \"Correo\")\n  const obtenerCampo = (nombreOriginal, alternativa) => {\n    const keys = Object.keys(item.json);\n    const encontrar = (busqueda) => keys.find(k => k.toLowerCase().trim() === busqueda.toLowerCase().trim());\n    \n    let claveEncontrada = encontrar(nombreOriginal);\n    if (!claveEncontrada && alternativa) {\n      claveEncontrada = encontrar(alternativa);\n    }\n    \n    const valor = claveEncontrada ? item.json[claveEncontrada] : \"\";\n    \n    // Si el valor es un array o un objeto de Notion, lo limpiamos para extraer solo el texto\n    if (Array.isArray(valor)) {\n      return valor[0] || \"\";\n    }\n    if (typeof valor === 'object' && valor !== null) {\n      return valor.email || valor.plain_text || valor.value || \"\";\n    }\n    return valor;\n  };\n\n  // Extraemos cada campo de forma ultra-segura\n  const nombre = obtenerCampo(\"Nombre\");\n  const correo = obtenerCampo(\"Mail\", \"Correo\"); // <--- Aquí busca primero \"Mail\" y si no, \"Correo\"\n  const categoria = obtenerCampo(\"Categoria de Auto\");\n  const ciudad = obtenerCampo(\"Ciudad\");\n  const dias = obtenerCampo(\"Cantidad de días\");\n  const detalle = obtenerCampo(\"Detalle del pedido\");\n\n  // Guardamos en el formato limpio de salida\n  item.json = {\n    nombre: typeof nombre === 'string' ? nombre.trim() : nombre,\n    correo: typeof correo === 'string' ? correo.trim() : correo,\n    categorías: typeof categoria === 'string' ? categoria.trim() : categoria,\n    ciudad: typeof ciudad === 'string' ? ciudad.trim() : ciudad,\n    dias: dias,\n    detalle: typeof detalle === 'string' ? detalle.trim() : detalle\n  };\n}\n\nreturn $input.all();"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
